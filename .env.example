# ── Frontend (Vite / Vercel) ──────────────────────────────────────────────────
VITE_API_URL=http://localhost:3001        # Production: your Railway backend URL
VITE_ANTHROPIC_API_KEY=                   # Anthropic API key for AI analysis
VITE_PLAID_CLIENT_ID=                     # Plaid client ID (also needed by backend)
VITE_PLAID_SECRET=                        # Plaid secret (sandbox or production)
VITE_PLAID_ENV=sandbox                    # sandbox | development | production

# ── Backend (Express / Railway) ───────────────────────────────────────────────
VITE_PLAID_CLIENT_ID=                     # Same as above
VITE_PLAID_SECRET=                        # Same as above
VITE_PLAID_ENV=sandbox                    # Same as above
FRONTEND_URL=                             # Your Vercel frontend URL (for CORS)
PORT=3001                                 # Railway sets this automatically
